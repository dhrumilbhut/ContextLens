# Copy this to .env and fill in your values before running test_manual_pattern.py

# Your project's API key — create one via the dashboard at http://localhost:3000
CONTEXTLENS_API_KEY=cl_your_key_here

# Your project's UUID — shown in the dashboard URL when you open the project
CONTEXTLENS_PROJECT_ID=your-project-uuid-here

# Leave these as-is for local dev
CONTEXTLENS_API_URL=http://localhost:8000
