# ── LLM ──────────────────────────────────────────────────────────────────────
# Required. Used by the Celery worker for claim decomposition and faithfulness scoring.
OPENAI_API_KEY=sk-your-openai-key-here

# LLM models used by the attribution pipeline.
# gpt-4o-mini is the default — cheap, fast, good at structured JSON output.
CONTEXTLENS_DECOMPOSE_MODEL=gpt-4o-mini
CONTEXTLENS_JUDGE_MODEL=gpt-4o-mini

# Embedding model. MUST match the embedding model used in the developer's RAG pipeline.
# If your RAG system uses a different model, change this to match — mismatched embeddings
# produce meaningless similarity scores and broken attribution.
CONTEXTLENS_EMBEDDING_MODEL=text-embedding-3-small

# ── Local API Key ─────────────────────────────────────────────────────────────
# The SDK uses this key to authenticate with the ingest API.
# Set any string here — just make it something unique and keep it consistent
# between this file (server side) and your RAG app's .env (client side, as CONTEXTLENS_API_KEY).
CONTEXTLENS_LOCAL_API_KEY=local_dev_key_change_me

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=contextlens
POSTGRES_PASSWORD=contextlens
POSTGRES_DB=contextlens
DATABASE_URL=postgresql://contextlens:contextlens@postgres:5432/contextlens

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Pipeline Settings ─────────────────────────────────────────────────────────
# Minimum cosine similarity for a chunk to count as the source of a claim.
# Claims below this threshold are marked as unattributed (hallucination signal).
ATTRIBUTION_THRESHOLD=0.75

# Max traces processed (through LLM pipeline) per project per day.
# Protects your OpenAI bill from accidental loops. Set to 0 to disable.
DAILY_PROCESSING_LIMIT=10000

# Rate limits on the ingest endpoint.
HOURLY_INGEST_RATE_LIMIT=1000
PER_MINUTE_RATE_LIMIT=100

# ── Clustering ────────────────────────────────────────────────────────────────
# How many clusters to group queries into per project.
CLUSTERING_K=8

# How often the clustering Celery beat job runs (in seconds). Default: every 6 hours.
CLUSTERING_INTERVAL_SECONDS=21600

# Minimum number of traces in a project before clustering runs.
CLUSTERING_MIN_TRACES=20

# ── Dashboard ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
