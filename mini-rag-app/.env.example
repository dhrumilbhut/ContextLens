# Copy this to .env and fill in your values before running the mini RAG app.

# Your OpenAI API key — used by the RAG app for embeddings and generation
OPENAI_API_KEY=sk-your-openai-key-here

# API key for the "Mini RAG Test App" project in the ContextLens dashboard.
# Create a new project named "Mini RAG Test App", generate an API key for it,
# and paste it here. Using a dedicated project keeps these traces separate
# from all prior test data.
CONTEXTLENS_API_KEY=cl_your_key_here

# Leave as-is for local dev
CONTEXTLENS_API_URL=http://localhost:8000
